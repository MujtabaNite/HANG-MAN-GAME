[ 127]        :                                       ; HANGMAN GAME - MODULARIZED VERSION
[ 128]        :                                       ; ========================================================================
[ 129]        :                                       ; This is a complete hangman game implementation in x86 assembly language
[ 130]        :                                       ; The game displays a gallows, manages word guessing, and tracks mistakes
[ 131]        :                                       ; ========================================================================
[ 132]        :                                       
[ 133]        :                                       code segment
[ 134]    0330:                                       start:
[ 135]        :                                       ; Initialize data and extra segments
[ 136]    0330: B8 10 00                              mov ax, data            ; Load data segment address into AX
[ 137]    0333: 8E D8                                 mov ds, ax              ; Set DS to point to data segment
[ 138]    0335: 8E C0                                 mov es, ax              ; Set ES to point to data segment
[ 139]        :                                       
[ 140]        :                                       ; Set graphics mode (320x200, 256 colors)
[ 141]    0337: B4 00                                 mov ah, 0               ; BIOS video function: set video mode
[ 142]    0339: B0 0D                                 mov al, 0dh             ; Video mode 13h (320x200, 256 colors)
[ 143]    033B: CD 10                                 int 10h                 ; Call BIOS video interrupt
[ 144]        :                                       
[ 145]        :                                       ; Set ES to point to video memory
[ 146]    033D: BE 00 A0                              mov si, 0a000h          ; Video memory segment address
[ 147]    0340: 8E C6                                 mov es, si              ; Point ES to video memory
[ 148]        :                                       
[ 149]    0342: EB 00                                 jmp the_beginning       ; Jump to main game initialization
[ 150]        :                                       
[ 151]        :                                       ; ========================================================================
[ 152]        :                                       ; PROCEDURE: GAME_INITIALIZATION
[ 153]        :                                       ; Description: Initializes all game variables and starts the main game loop
[ 154]        :                                       ; Input: None
[ 155]        :                                       ; Output: None
[ 156]        :                                       ; Modifies: AX, BX, CX, DX, SI, DI
[ 157]        :                                       ; ========================================================================
[ 158]    0344:                                       the_beginning:
[ 159]        :                                       ; Clear all general-purpose registers
[ 160]    0344: 33 DB                                 xor bx, bx              ; Clear BX register
[ 161]    0346: 33 C0                                 xor ax, ax              ; Clear AX register
[ 162]    0348: 33 C9                                 xor cx, cx              ; Clear CX register
[ 163]    034A: 33 D2                                 xor dx, dx              ; Clear DX register
[ 164]    034C: 33 F6                                 xor si, si              ; Clear SI register
[ 165]    034E: 33 FF                                 xor di, di              ; Clear DI register
[ 166]        :                                       
[ 167]        :                                       ; Initialize game variables
[ 168]    0350: C6 06 6A 01 00                        mov mistakes, 0                     ; Reset mistake counter to 0
[ 169]    0355: C6 06 6B 01 00                        mov success_guess_counter, 0        ; Reset successful guess counter
[ 170]        :                                       
[ 171]        :                                       ; Set initial drawing position for gallows
[ 172]    035A: C7 06 53 00 02 00                     mov column_a, 2         ; Starting column position
[ 173]    0360: C7 06 51 00 09 00                     mov line, 9             ; Starting line position
[ 174]        :                                       
[ 175]    0366: EB 00                                 jmp shows_hang_vertical ; Jump to gallows drawing routine
[ 176]        :                                       
[ 177]        :                                       ; ========================================================================
[ 178]        :                                       ; PROCEDURE: DRAW_VERTICAL_GALLOWS
[ 179]        :                                       ; Description: Draws the vertical part of the gallows structure
[ 180]        :                                       ; Input: BL (counter), line, column_a (position variables)
[ 181]        :                                       ; Output: Vertical gallows displayed on screen
[ 182]        :                                       ; Modifies: BL, SI, line
[ 183]        :                                       ; ========================================================================
[ 184]    0368:                                       shows_hang_vertical:
[ 185]    0368: BE 00 00                              lea si, hang_ve         ; Load address of vertical hangman character
[ 186]        :                                       
[ 187]    036B: 80 FB 08                              cmp bl, 8               ; Check if we've drawn 8 vertical lines
[ 188]    036E: 74 0B                                 je shows_hang_horizontal ; If yes, move to horizontal part
[ 189]        :                                       
[ 190]    0370: E8 52 04                              call shows_letter       ; Display the vertical character
[ 191]        :                                       
[ 192]    0373: FE C3                                 inc bl                  ; Increment counter
[ 193]    0375: FF 06 51 00                           inc line                ; Move to next line
[ 194]    0379: EB ED                                 jmp shows_hang_vertical ; Continue drawing vertical lines
[ 195]        :                                       
[ 196]        :                                       ; ========================================================================
[ 197]        :                                       ; PROCEDURE: DRAW_HORIZONTAL_GALLOWS
[ 198]        :                                       ; Description: Draws the horizontal part of the gallows structure
[ 199]        :                                       ; Input: BX (counter), line, column_a (position variables)
[ 200]        :                                       ; Output: Horizontal gallows displayed on screen
[ 201]        :                                       ; Modifies: BX, SI, column_a, line
[ 202]        :                                       ; ========================================================================
[ 203]    037B:                                       shows_hang_horizontal:
[ 204]    037B: BB 00 00                              mov bx, 0               ; Reset counter for horizontal drawing
[ 205]    037E: C7 06 53 00 02 00                     mov column_a, 2         ; Reset column position
[ 206]    0384: C7 06 51 00 09 00                     mov line, 9             ; Reset line position
[ 207]        :                                       
[ 208]    038A:                                       repeat_hang_horizontal:
[ 209]    038A: BE 09 00                              lea si, hang_ho         ; Load address of horizontal hangman character
[ 210]        :                                       
[ 211]    038D: 80 FB 04                              cmp bl, 4               ; Check if we've drawn 4 horizontal characters
[ 212]    0390: 74 0B                                 je shows_rope           ; If yes, move to rope drawing
[ 213]        :                                       
[ 214]    0392: E8 30 04                              call shows_letter       ; Display the horizontal character
[ 215]        :                                       
[ 216]    0395: FE C3                                 inc bl                  ; Increment counter
[ 217]    0397: FF 06 53 00                           inc column_a            ; Move to next column
[ 218]    039B: EB ED                                 jmp repeat_hang_horizontal ; Continue drawing horizontal lines
[ 219]        :                                       
[ 220]        :                                       ; ========================================================================
[ 221]        :                                       ; PROCEDURE: DRAW_ROPE
[ 222]        :                                       ; Description: Draws the hanging rope part of the gallows
[ 223]        :                                       ; Input: None
[ 224]        :                                       ; Output: Rope displayed at specified position
[ 225]        :                                       ; Modifies: column_a, line, SI
[ 226]        :                                       ; ========================================================================
[ 227]    039D:                                       shows_rope:
[ 228]    039D: C7 06 53 00 05 00                     mov column_a, 5         ; Set rope column position
[ 229]    03A3: C7 06 51 00 0A 00                     mov line, 10            ; Set rope line position
[ 230]    03A9: BE 12 00                              lea si, rope            ; Load address of rope character
[ 231]    03AC: E8 16 04                              call shows_letter       ; Display the rope
[ 232]        :                                       
[ 233]    03AF: EB 00                                 jmp begin               ; Jump to word processing initialization
[ 234]        :                                       
[ 235]        :                                       ; ========================================================================
[ 236]        :                                       ; PROCEDURE: INITIALIZE_WORD_DISPLAY
[ 237]        :                                       ; Description: Processes the target word and creates display lines
[ 238]        :                                       ; Input: str_word (target word string)
[ 239]        :                                       ; Output: str_lines (display format with underscores)
[ 240]        :                                       ; Modifies: BX, AL, str_lines array
[ 241]        :                                       ; ========================================================================
[ 242]    03B1:                                       begin:
[ 243]    03B1: BB 00 00                              mov bx, 0               ; Initialize index counter
[ 244]        :                                       
[ 245]    03B4:                                       fills_str_lines:
[ 246]    03B4: 80 BF 5C 01 24                        cmp str_word[bx],"$"    ; Check for end of string marker
[ 247]    03B9: 74 1B                                 je  continues           ; If end found, continue to next phase
[ 248]        :                                       
[ 249]    03BB: 80 BF 5C 01 20                        cmp str_word[bx]," "    ; Check if current character is space
[ 250]    03C0: 74 0A                                 je  str_spaceline       ; If space, handle differently
[ 251]        :                                       
[ 252]        :                                       ; For regular letters, show underscore
[ 253]    03C2: A0 5A 01                              mov al,str_line         ; Load underscore character
[ 254]    03C5: 88 87 2F 02                           mov str_lines[bx], al   ; Store underscore in display array
[ 255]        :                                       
[ 256]    03C9: 43                                    inc bx                  ; Move to next character
[ 257]    03CA: EB E8                                 jmp fills_str_lines     ; Continue processing
[ 258]        :                                       
[ 259]    03CC:                                       str_spaceline:
[ 260]        :                                       ; For spaces, show empty space in display
[ 261]    03CC: A0 5B 01                              mov al,str_empty        ; Load empty space character
[ 262]    03CF: 88 87 2F 02                           mov str_lines[bx], al   ; Store space in display array
[ 263]    03D3: 43                                    inc bx                  ; Move to next character
[ 264]    03D4: EB DE                                 jmp fills_str_lines     ; Continue processing
[ 265]        :                                       
[ 266]        :                                       ; ========================================================================
[ 267]        :                                       ; PROCEDURE: CALCULATE_WORD_SIZE
[ 268]        :                                       ; Description: Calculates the size of the word excluding spaces
[ 269]        :                                       ; Input: str_word (target word)
[ 270]        :                                       ; Output: size_none, size_none_minor (word length variables)
[ 271]        :                                       ; Modifies: BX, DL, size_none, size_none_minor
[ 272]        :                                       ; ========================================================================
[ 273]    03D6:                                       continues:
[ 274]        :                                       ; Calculate total word size
[ 275]    03D6: BB 68 01                              mov bx,offset size_none ; Get address of size variable
[ 276]    03D9: 81 EB 5C 01                           sub bx,offset str_word  ; Subtract word start address
[ 277]    03DD: 83 EB 01                              sub bx, 1               ; Adjust for zero-based indexing
[ 278]    03E0: 88 1E 68 01                           mov size_none,bl        ; Store total size
[ 279]        :                                       
[ 280]    03E4: BB 00 00                              mov bx, 0               ; Reset index
[ 281]    03E7: 8A 16 68 01                           mov dl, size_none       ; Copy size to working variable
[ 282]    03EB: 88 16 69 01                           mov size_none_minor, dl ; Store working size
[ 283]        :                                       
[ 284]    03EF:                                       counts_space_lines:
[ 285]    03EF: 80 BF 5C 01 20                        cmp str_word[bx], 32    ; Check if character is space (ASCII 32)
[ 286]    03F4: 74 0A                                 je discard_space_lines  ; If space, don't count it
[ 287]    03F6: 80 BF 5C 01 24                        cmp str_word[bx], "$"   ; Check for end of string
[ 288]    03FB: 74 0B                                 je continues_two        ; If end, continue to display
[ 289]        :                                       
[ 290]    03FD: 43                                    inc bx                  ; Move to next character
[ 291]    03FE: EB EF                                 jmp counts_space_lines  ; Continue counting
[ 292]        :                                       
[ 293]    0400:                                       discard_space_lines:
[ 294]    0400: 43                                    inc bx                  ; Move past the space
[ 295]    0401: 80 2E 69 01 01                        sub size_none_minor, 1  ; Reduce count (don't count spaces)
[ 296]    0406: EB E7                                 jmp counts_space_lines  ; Continue counting
[ 297]        :                                       
[ 298]        :                                       ; ========================================================================
[ 299]        :                                       ; PROCEDURE: DISPLAY_WORD_LINES
[ 300]        :                                       ; Description: Displays the word as underscores/spaces on screen
[ 301]        :                                       ; Input: str_lines (processed word display), size_none
[ 302]        :                                       ; Output: Word display rendered on screen
[ 303]        :                                       ; Modifies: BX, CL, SI, DI, AL, column_a, line
[ 304]        :                                       ; ========================================================================
[ 305]    0408:                                       continues_two:
[ 306]        :                                       ; Set display position for word
[ 307]    0408: C7 06 51 00 0E 00                     mov line,14             ; Set line position for word display
[ 308]    040E: C7 06 53 00 10 00                     mov column_a,16         ; Set starting column position
[ 309]    0414: BB 00 00                              mov bx,0                ; Reset character index
[ 310]    0417: B1 00                                 mov cl,0                ; Reset character counter
[ 311]        :                                       
[ 312]    0419:                                       shows_str_lines:
[ 313]    0419: 8D B7 2F 02                           lea si,str_lines[bx]    ; Load address of current display character
[ 314]        :                                       
[ 315]    041D: 3A 0E 68 01                           cmp cl,size_none        ; Check if all characters processed
[ 316]    0421: 74 26                                 je  show_msg_top        ; If done, show top message
