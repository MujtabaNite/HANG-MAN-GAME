[ 743]        :                                       ; PROCEDURE: CLEAR_SCREEN
[ 744]        :                                       ; Description: Clears the entire screen by filling video memory with zeros
[ 745]        :                                       ; Input: None
[ 746]        :                                       ; Output: Screen cleared to black
[ 747]        :                                       ; Modifies: AX, ES, DI, CX
[ 748]        :                                       ; ========================================================================
[ 749]    0692:                                       clean_screen:
[ 750]    0692: B8 00 A0                              mov ax,0a000h           ; Video memory segment
[ 751]    0695: 8E C0                                 mov es,ax               ; Point ES to video memory
[ 752]    0697: 33 FF                                 xor di,di               ; Start at beginning of video memory
[ 753]    0699: 33 C0                                 xor ax,ax               ; Clear AX (value to fill with)
[ 754]    069B: B9 00 7D                              mov cx,32000d           ; Number of words to clear (64000 bytes / 2)
[ 755]    069E: FC                                    cld                     ; Clear direction flag (forward)
[ 756]    069F: F3 AB                                 rep stosw               ; Repeat store word (clear screen)
[ 757]    06A1: C3                                    ret                     ; Return to caller
