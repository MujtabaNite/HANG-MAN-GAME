[ 856]        :                                       ; ========================================================================
[ 857]        :                                       ; PROCEDURE: CALCULATE_SCREEN_POSITION
[ 858]        :                                       ; Description: Converts line/column coordinates to video memory address
[ 859]        :                                       ; Input: line, column_a (screen coordinates)
[ 860]        :                                       ; Output: DI (video memory offset)
[ 861]        :                                       ; Modifies: AX, BX, DI (preserves original values on stack)
[ 862]        :                                       ; ========================================================================
[ 863]    0795:                                       calculate_line_and_column:
[ 864]    0795: FF 36 51 00                           push line               ; Save line value
[ 865]    0799: FF 36 53 00                           push column_a           ; Save column value
[ 866]    079D: 50                                    push ax                 ; Save AX register
[ 867]    079E: 53                                    push bx                 ; Save BX register
[ 868]        :                                       
[ 869]    079F: BF 00 00                              mov di, 0               ; Initialize DI
[ 870]        :                                       
[ 871]        :                                       ; Calculate line offset: line * 40 * 8
[ 872]    07A2: A1 51 00                              mov ax, line            ; Load line number
[ 873]    07A5: BB 28 00                              mov bx, 40              ; 40 characters per line
[ 874]    07A8: F7 E3                                 mul bx                  ; AX = line * 40
[ 875]        :                                       
[ 876]    07AA: BB 08 00                              mov bx, 08              ; 8 pixels per character height
[ 877]    07AD: F7 E3                                 mul bx                  ; AX = line * 40 * 8
[ 878]        :                                       
[ 879]    07AF: A3 51 00                              mov line, ax            ; Store calculated line offset
[ 880]        :                                       
[ 881]    07B2: 03 3E 53 00                           add di, column_a        ; Add column offset
[ 882]    07B6: 03 3E 51 00                           add di, line            ; Add line offset
[ 883]        :                                       
[ 884]    07BA: 5B                                    pop bx                  ; Restore BX
[ 885]    07BB: 58                                    pop ax                  ; Restore AX
[ 886]    07BC: 8F 06 53 00                           pop column_a            ; Restore column_a
[ 887]    07C0: 8F 06 51 00                           pop line                ; Restore line
[ 888]        :                                       
[ 889]    07C4: C3                                    ret                     ; Return with DI = video memory offset
[ 890]        :                                       
[ 891]        :                                       ; ========================================================================
[ 892]        :                                       ; PROCEDURE: DISPLAY_CHARACTER_BITMAP
[ 893]        :                                       ; Description: Displays a character bitmap at current screen position
[ 894]        :                                       ; Input: SI (pointer to character data), DI (screen position)
[ 895]        :                                       ; Output: Character displayed on screen
[ 896]        :                                       ; Modifies: DL, DI, SI
[ 897]        :                                       ; ========================================================================
[ 898]    07C5:                                       shows_letter:
[ 899]    07C5: E8 CD FF                              call calculate_line_and_column ; Calculate screen position
[ 900]        :                                       
[ 901]    07C8:                                       writes:
[ 902]    07C8: 8A 14                                 mov dl, [si]            ; Load byte from character data
[ 903]    07CA: 80 FA 24                              cmp dl, "$"             ; Check for end marker
[ 904]    07CD: 74 09                                 je returns              ; If end, return
[ 905]        :                                       
[ 906]    07CF: 26 88 15                              mov es:[di], dl         ; Write byte to video memory
[ 907]        :                                       
[ 908]    07D2: 83 C7 28                              add di, 40              ; Move to next line (40 bytes per line)
[ 909]    07D5: 46                                    inc si                  ; Move to next byte in character data
[ 910]    07D6: EB F0                                 jmp writes              ; Continue writing
[ 911]        :                                       
[ 912]    07D8:                                       returns:
[ 913]    07D8: C3                                    ret                     ; Return to caller
[ 914]        :                                       
[ 915]        :                                       ; ========================================================================
[ 916]        :                                       ; PROCEDURE: DISPLAY_SINGLE_CHARACTER
[ 917]        :                                       ; Description: Displays a single character at calculated position
[ 918]        :                                       ; Input: SI (character pointer), screen position variables
[ 919]        :                                       ; Output: Single character displayed
[ 920]        :                                       ; Modifies: AL, DI
[ 921]        :                                       ; ========================================================================
[ 922]    07D9:                                       shows_str_line:
[ 923]    07D9: E8 B9 FF                              call calculate_line_and_column ; Calculate screen position
[ 924]        :                                       
[ 925]    07DC: 8A 04                                 mov al, [si]            ; Load character
[ 926]    07DE: 26 88 05                              mov es:[di], al         ; Write to video memory
[ 927]        :                                       
[ 928]    07E1: C3                                    ret                     ; Return
[ 929]        :                                       
[ 930]        :                                       ; ========================================================================
[ 931]        :                                       ; PROCEDURE: CLEAR_GUESS_ARRAY
[ 932]        :                                       ; Description: Clears the array storing previous guesses
[ 933]        :                                       ; Input: str_guess array
[ 934]        :                                       ; Output: Array filled with string terminators
[ 935]        :                                       ; Modifies: DI, str_guess array
[ 936]        :                                       ; ========================================================================
[ 937]    07E2:                                       clean_guess:
[ 938]    07E2: BF 00 00                              mov di, 0               ; Initialize index
[ 939]        :                                       
[ 940]    07E5:                                       repeat_lmp_palp:
[ 941]    07E5: C6 85 6C 01 24                        mov str_guess[di], "$"  ; Set terminator
[ 942]        :                                       
[ 943]    07EA: 83 FF 19                              cmp di, 25              ; Check if end of array reached
[ 944]    07ED: 74 10                                 je clean_done           ; If yes, finish
[ 945]        :                                       
[ 946]    07EF: 47                                    inc di                  ; Move to next position
[ 947]        :                                       
[ 948]    07F0: EB F3                                 jmp repeat_lmp_palp     ; Continue clearing
[ 949]        :                                       
[ 950]        :                                       ; ========================================================================
[ 951]        :                                       ; PROCEDURE: RESTART_GAME_HANDLER
[ 952]        :                                       ; Description: Handles game restart input and cleanup
[ 953]        :                                       ; Input: User keypress
[ 954]        :                                       ; Output: Game restarted or terminated
[ 955]        :                                       ; Modifies: AX, screen display
[ 956]        :                                       ; ========================================================================
[ 957]    07F2:                                       restart:
[ 958]    07F2: B4 08                                 mov ah, 08              ; Get character input
[ 959]    07F4: CD 21                                 int 21h                 ; Call DOS interrupt
[ 960]        :                                       
[ 961]    07F6: 50                                    push ax                 ; Save input character
[ 962]    07F7: E8 98 FE                              call clean_screen       ; Clear the screen
[ 963]    07FA: 58                                    pop ax                  ; Restore input character
[ 964]        :                                       
[ 965]    07FB: 57                                    push di                 ; Save DI register
[ 966]    07FC: E8 E3 FF                              call clean_guess        ; Clear previous guesses
[ 967]        :                                       
[ 968]    07FF:                                       clean_done:
[ 969]    07FF: 5F                                    pop di                  ; Restore DI register
[ 970]    0800: E9 47 FE                              jmp the_end             ; Jump to program termination
[ 971]        :                                       
[ 972]        :                                       ; ========================================================================
[ 973]        :                                       ; PROCEDURE: CONVERT_ASCII_TO_BITMAP
[ 974]        :                                       ; Description: Converts ASCII text string to bitmap display characters
[ 975]        :                                       ; Input: SI (pointer to ASCII string), position variables
[ 976]        :                                       ; Output: Text displayed as bitmap characters on screen
[ 977]        :                                       ; Modifies: AX, BX, DX, DI, SI, column_a
[ 978]        :                                       ; ========================================================================
[ 979]    0803:                                       ascii_to_bitmap:
[ 980]    0803: 50                                    push ax                 ; Save AX register
[ 981]    0804: 53                                    push bx                 ; Save BX register
[ 982]    0805: 52                                    push dx                 ; Save DX register
[ 983]    0806: 57                                    push di                 ; Save DI register
[ 984]        :                                       
[ 985]    0807:                                       repeat_ascii_to_bitmap:
[ 986]    0807: B4 00                                 mov ah, 0               ; Clear high byte of AX
[ 987]    0809: 8A 04                                 mov al, [si]            ; Load current character
[ 988]    080B: 2C 41                                 sub al, 65              ; Convert to alphabet index (A=0, B=1, etc.)
[ 989]    080D: B2 02                                 mov dl, 2               ; Each alphabet entry is 2 bytes
[ 990]    080F: F6 E2                                 mul dl                  ; Calculate offset in alphabet array
[ 991]        :                                       
[ 992]    0811: 80 3C 24                              cmp [si], "$"           ; Check for string terminator
[ 993]    0814: 74 17                                 je word_finished        ; If end of string, finish
[ 994]    0816: 80 3C 20                              cmp [si], " "           ; Check for space character
[ 995]    0819: 74 0B                                 je empty_space          ; If space, handle differently
[ 996]        :                                       
[ 997]    081B: 8B F8                                 mov di, ax              ; Store alphabet offset in DI
[ 998]        :                                       
[ 999]    081D: 56                                    push si                 ; Save string pointer
[1000]    081E: 8B B5 F5 01                           mov si, alphabet[di]    ; Get bitmap address for character
[1001]    0822: E8 A0 FF                              call shows_letter       ; Display the character bitmap
[1002]    0825: 5E                                    pop si                  ; Restore string pointer
[1003]        :                                       
[1004]    0826:                                       empty_space:
[1005]    0826: FF 06 53 00                           inc column_a            ; Move to next column position
[1006]    082A: 46                                    inc si                  ; Move to next character in string
[1007]        :                                       
[1008]    082B: EB DA                                 jmp repeat_ascii_to_bitmap ; Continue processing string
[1009]        :                                       
[1010]    082D:                                       word_finished:
[1011]    082D: 58                                    pop ax                  ; Restore AX register
[1012]    082E: 5B                                    pop bx                  ; Restore BX register
[1013]    082F: 5A                                    pop dx                  ; Restore DX register
[1014]    0830: 5F                                    pop di                  ; Restore DI register
[1015]    0831: C3                                    ret                     ; Return to caller
[1016]        :                                       
[1017]        :                                       ends                        ; End of code segment
[1018]        :                                       end start                   ; End of program, entry point is 'start'
[1019]        :                                       
 
===================================================================================================
 
EXE HEADER - bytes from 0000 to 01FF inclusive.

0000: 4D      -   exe signature (M)
0001: 5A      -   exe signature (Z)
0002: 32      -   bytes on last page (l.byte)
0003: 00      -   bytes on last page (h.byte)
0004: 06      -   512 byte pages in file (l.byte)
0005: 00      -   512 byte pages in file (h.byte)
0006: 01      -   relocations (l.byte)
0007: 00      -   relocations (h.byte)
0008: 20      -   paragraphs in header (l.byte)
0009: 00      -   paragraphs in header (h.byte)
000A: 00      -   minimum memory (l.byte)
000B: 00      -   minimum memory (h.byte)
000C: FF      -   maximum memory (l.byte)
000D: FF      -   maximum memory (h.byte)
000E: 00      -   SS - stack segment (l.byte)
000F: 00      -   SS - stack segment (h.byte)
0010: 00      -   SP - stack pointer (l.byte)
0011: 01      -   SP - stack pointer (h.byte)
0012: D7      -   check sum (l.byte)
0013: E2      -   check sum (h.byte)
0014: 00      -   IP - instruction pointer (l.byte)
0015: 00      -   IP - instruction pointer (h.byte)
0016: 33      -   CS - code segment (l.byte)
0017: 00      -   CS - code segment (h.byte)
0018: 1E      -   relocation table adress (l.byte)
0019: 00      -   relocation table adress (h.byte)
001A: 00      -   overlay number (l.byte)
001B: 00      -   overlay number (h.byte)
001C: 01      -   signature (l.byte)
001D: 00      -   signature (h.byte)
001E: 01      -   relocation table - offset inside segment (l.byte)
001F: 00      -   relocation table - offset inside segment (h.byte)
0020: 33      -   relocation table - segment anchor (l.byte)
0021: 00      -   relocation table - segment anchor (h.byte)
0022 to 01FF  -   reserved relocation area  (00) 




===================================================================================================
